# Azure AI Language (Text Analytics) credentials
# Create a resource at https://portal.azure.com → Azure AI services → Language service
AZURE_LANGUAGE_ENDPOINT=https://<your-resource-name>.cognitiveservices.azure.com/
AZURE_LANGUAGE_KEY=<your-32-char-key>

# Azure OpenAI credentials (optional — enables context-aware speaker role detection)
# Create a resource at https://portal.azure.com → Azure OpenAI
# Then deploy a model (e.g. gpt-5-mini) in Microsoft Foundry / Azure AI Studio
# and set its exact deployment name below
AZURE_OPENAI_ENDPOINT=https://<your-openai-resource>.openai.azure.com/
AZURE_OPENAI_KEY=<your-openai-key>
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini
